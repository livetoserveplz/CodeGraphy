{
	"name": "codegraphy-monorepo",
	"private": true,
	"version": "0.1.0",
	"packageManager": "pnpm@10.32.0",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"vscode:prepublish": "pnpm run build",
		"build": "turbo run build",
		"build:extension": "pnpm --filter @codegraphy/extension run build:extension",
		"build:webview": "pnpm --filter @codegraphy/extension run build:webview",
		"watch": "pnpm --filter @codegraphy/extension run watch",
		"watch:extension": "pnpm --filter @codegraphy/extension run watch:extension",
		"watch:webview": "pnpm --filter @codegraphy/extension run watch:webview",
		"dev": "pnpm --filter @codegraphy/extension run dev",
		"test": "turbo run test",
		"test:playwright": "playwright test",
		"test:playwright:ui": "playwright test --ui",
		"playwright:install": "playwright install chromium",
		"test:watch": "pnpm --filter @codegraphy/extension run test:watch",
		"lint": "turbo run lint && pnpm run lint:playwright",
		"lint:playwright": "eslint tests/playwright --max-warnings=0",
		"crap": "pnpm --filter @codegraphy/quality-tools run crap --",
		"boundaries": "pnpm --filter @codegraphy/quality-tools run boundaries --",
		"reachability": "pnpm --filter @codegraphy/quality-tools run reachability --",
		"mutate": "pnpm --filter @codegraphy/quality-tools run mutate --",
		"scrap": "pnpm --filter @codegraphy/quality-tools run scrap --",
		"organize": "pnpm --filter @codegraphy/quality-tools run organize --",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"typecheck": "turbo run typecheck",
		"typecheck:extension": "pnpm --filter @codegraphy/extension run typecheck",
		"typecheck:plugin-api": "pnpm --filter @codegraphy/plugin-api run typecheck",
		"typecheck:plugins": "turbo run typecheck --filter=@codegraphy/plugin-typescript --filter=@codegraphy/plugin-python --filter=@codegraphy/plugin-csharp --filter=@codegraphy/plugin-godot --filter=@codegraphy/plugin-markdown",
		"prepare": "husky",
		"test:e2e": "pnpm run build:e2e && node dist-e2e/e2e/runTest.js",
		"build:e2e": "pnpm run build && tsc -p packages/extension/src/e2e/tsconfig.json"
	},
	"displayName": "CodeGraphy",
	"description": "Visualize your codebase as an interactive 2D force graph",
	"publisher": "joesobo",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Visualization",
		"Other"
	],
	"keywords": [
		"graph",
		"visualization",
		"dependencies",
		"imports",
		"codebase"
	],
	"activationEvents": [],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "codegraphy.open",
				"title": "CodeGraphy: Open"
			},
			{
				"command": "codegraphy.openInEditor",
				"title": "CodeGraphy: Open in Editor"
			},
			{
				"command": "codegraphy.fitView",
				"title": "CodeGraphy: Fit All Nodes in View"
			},
			{
				"command": "codegraphy.zoomIn",
				"title": "CodeGraphy: Zoom In"
			},
			{
				"command": "codegraphy.zoomOut",
				"title": "CodeGraphy: Zoom Out"
			},
			{
				"command": "codegraphy.undo",
				"title": "CodeGraphy: Undo"
			},
			{
				"command": "codegraphy.redo",
				"title": "CodeGraphy: Redo"
			},
			{
				"command": "codegraphy.exportPng",
				"title": "CodeGraphy: Export as PNG"
			},
			{
				"command": "codegraphy.exportSvg",
				"title": "CodeGraphy: Export as SVG"
			},
			{
				"command": "codegraphy.exportJpeg",
				"title": "CodeGraphy: Export as JPEG"
			},
			{
				"command": "codegraphy.exportJson",
				"title": "CodeGraphy: Export Connections as JSON"
			},
			{
				"command": "codegraphy.exportMarkdown",
				"title": "CodeGraphy: Export Connections as Markdown"
			},
			{
				"command": "codegraphy.clearCache",
				"title": "CodeGraphy: Clear Cache and Refresh"
			},
			{
				"command": "codegraphy.cycleView",
				"title": "CodeGraphy: Cycle View"
			},
			{
				"command": "codegraphy.cycleLayout",
				"title": "CodeGraphy: Cycle Layout"
			},
			{
				"command": "codegraphy.toggleDimension",
				"title": "CodeGraphy: Toggle 2D/3D"
			}
		],
		"keybindings": [
			{
				"command": "codegraphy.fitView",
				"key": "0",
				"when": "codegraphy.graphFocused"
			},
			{
				"command": "codegraphy.zoomIn",
				"key": "=",
				"when": "codegraphy.graphFocused"
			},
			{
				"command": "codegraphy.zoomIn",
				"key": "shift+=",
				"when": "codegraphy.graphFocused"
			},
			{
				"command": "codegraphy.zoomOut",
				"key": "-",
				"when": "codegraphy.graphFocused"
			},
			{
				"command": "codegraphy.undo",
				"key": "ctrl+z",
				"mac": "cmd+z",
				"when": "codegraphy.viewVisible && activeViewlet == 'workbench.view.extension.codegraphy' && !editorTextFocus && !inputFocus"
			},
			{
				"command": "codegraphy.redo",
				"key": "ctrl+shift+z",
				"mac": "cmd+shift+z",
				"when": "codegraphy.viewVisible && activeViewlet == 'workbench.view.extension.codegraphy' && !editorTextFocus && !inputFocus"
			},
			{
				"command": "codegraphy.redo",
				"key": "ctrl+y",
				"when": "codegraphy.viewVisible && activeViewlet == 'workbench.view.extension.codegraphy' && !editorTextFocus && !inputFocus"
			},
			{
				"command": "codegraphy.cycleView",
				"key": "v",
				"when": "codegraphy.graphFocused"
			},
			{
				"command": "codegraphy.cycleLayout",
				"key": "l",
				"when": "codegraphy.graphFocused"
			},
			{
				"command": "codegraphy.toggleDimension",
				"key": "t",
				"when": "codegraphy.graphFocused"
			}
		],
		"viewsContainers": {
				"activitybar": [
					{
						"id": "codegraphy",
						"title": "CodeGraphy",
						"icon": "assets/icon.svg"
					}
				]
			},
		"views": {
			"codegraphy": [
				{
					"type": "webview",
					"id": "codegraphy.graphView",
					"name": "Graph"
				}
			]
		},
		"configuration": {
			"title": "CodeGraphy",
			"properties": {
				"codegraphy.maxFiles": {
					"type": "number",
					"default": 500,
					"description": "Maximum number of files to analyze. Shows a warning if exceeded."
				},
				"codegraphy.include": {
					"type": "array",
					"items": "string",
					"default": [
						"**/*"
					],
					"description": "Glob patterns for files to include in analysis."
				},
				"codegraphy.respectGitignore": {
					"type": "boolean",
					"default": true,
					"description": "Also exclude files matched by .gitignore."
				},
				"codegraphy.showOrphans": {
					"type": "boolean",
					"default": true,
					"description": "Show files that have no connections (no imports and not imported)."
				},
				"codegraphy.plugins": {
					"type": "array",
					"items": "string",
					"default": [],
					"description": "List of CodeGraphy plugin extension names to enable (e.g., 'codegraphy-rust')."
				},
				"codegraphy.disabledRules": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Disabled plugin rules by qualified ID ('<pluginId>:<ruleId>'). Managed by the Plugins panel."
				},
				"codegraphy.disabledPlugins": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Disabled plugin IDs. Managed by the Plugins panel."
				},
				"codegraphy.hiddenPluginGroups": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Plugin default group IDs that have been hidden. Managed by the Groups panel."
				},
				"codegraphy.favorites": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "List of favorite file paths. Favorited files are displayed with a yellow outline in the graph."
				},
				"codegraphy.bidirectionalEdges": {
					"type": "string",
					"enum": [
						"separate",
						"combined"
					],
					"default": "separate",
					"enumDescriptions": [
						"Show two separate arrows for bidirectional connections",
						"Show a single bidirectional arrow with arrowheads on both ends"
					],
					"description": "How to display bidirectional connections (when A imports B and B imports A)."
				},
				"codegraphy.physics.repelForce": {
					"type": "number",
					"default": 10,
					"minimum": 0,
					"maximum": 20,
					"description": "Node repulsion strength (0 = no repel, 20 = max repel)."
				},
				"codegraphy.physics.linkDistance": {
					"type": "number",
					"default": 80,
					"minimum": 30,
					"maximum": 500,
					"description": "Preferred distance between connected nodes in pixels."
				},
				"codegraphy.physics.linkForce": {
					"type": "number",
					"default": 0.15,
					"minimum": 0,
					"maximum": 1,
					"description": "Spring stiffness — how strongly connected nodes pull together (0–1)."
				},
				"codegraphy.physics.damping": {
					"type": "number",
					"default": 0.7,
					"minimum": 0,
					"maximum": 1,
					"description": "How quickly motion settles. Higher = less jitter after dragging."
				},
				"codegraphy.physics.centerForce": {
					"type": "number",
					"default": 0.1,
					"minimum": 0,
					"maximum": 1,
					"description": "Pull toward the viewport center (0 = none, 1 = max)."
				},
				"codegraphy.groups": {
					"type": "array",
					"default": [],
					"description": "Groups for matching files. Each entry defines a glob pattern with color, shape, and optional image.",
					"items": {
						"type": "object",
						"properties": {
							"id": {
								"type": "string"
							},
							"pattern": {
								"type": "string"
							},
							"color": {
								"type": "string",
								"pattern": "^#[0-9A-Fa-f]{6}$"
							},
							"shape2D": {
								"type": "string",
								"enum": [
									"circle",
									"square",
									"diamond",
									"triangle",
									"hexagon",
									"star"
								]
							},
							"shape3D": {
								"type": "string",
								"enum": [
									"sphere",
									"cube",
									"octahedron",
									"cone",
									"dodecahedron",
									"icosahedron"
								]
							},
							"imagePath": {
								"type": "string",
								"description": "Workspace-relative path to image (e.g. .codegraphy/assets/icon.png)"
							},
							"disabled": {
								"type": "boolean",
								"description": "Whether this group is disabled (hidden from color/shape matching)"
							}
						}
					}
				},
				"codegraphy.filterPatterns": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Glob patterns for files to exclude from the graph (applied at discovery). Replaces codegraphy.exclude."
				},
				"codegraphy.showLabels": {
					"type": "boolean",
					"default": true,
					"description": "Show file name labels on graph nodes."
				},
				"codegraphy.directionMode": {
					"type": "string",
					"enum": [
						"arrows",
						"particles",
						"none"
					],
					"default": "arrows",
					"enumDescriptions": [
						"Static arrowheads at link endpoints",
						"Animated dots flowing along links",
						"No directional indicator"
					],
					"description": "How to indicate import direction on graph edges."
				},
				"codegraphy.directionColor": {
					"type": "string",
					"default": "#475569",
					"pattern": "^#[0-9A-Fa-f]{6}$",
					"description": "Directional indicator color as a hex value."
				},
				"codegraphy.folderNodeColor": {
					"type": "string",
					"default": "#A1A1AA",
					"pattern": "^#[0-9A-Fa-f]{6}$",
					"description": "Color for folder nodes in Folder View (hex format, e.g., #A1A1AA)."
				},
				"codegraphy.particleSpeed": {
					"type": "number",
					"default": 0.005,
					"minimum": 0.0005,
					"maximum": 0.005,
					"description": "Speed of directional particles (ratio of link length per frame)."
				},
				"codegraphy.particleSize": {
					"type": "number",
					"default": 4,
					"minimum": 1,
					"maximum": 10,
					"description": "Size (width) of directional particles in pixels."
				},
				"codegraphy.timeline.maxCommits": {
					"type": "number",
					"default": 500,
					"minimum": 10,
					"maximum": 5000,
					"description": "Maximum number of commits to index for the timeline feature."
				},
				"codegraphy.timeline.playbackSpeed": {
					"type": "number",
					"default": 1,
					"minimum": 0.1,
					"maximum": 10,
					"description": "Timeline playback speed multiplier (1.0 = ~2 days per second)."
				}
			}
		}
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"@eslint/js": "^9.0.0",
		"@playwright/test": "^1.58.2",
		"@stryker-mutator/core": "^9.6.0",
		"@stryker-mutator/vitest-runner": "^9.6.0",
		"@testing-library/jest-dom": "^6.2.0",
		"@testing-library/react": "^14.1.2",
		"@types/glob": "^8.1.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^20.11.0",
		"@types/react": "^18.2.48",
		"@types/react-dom": "^18.2.18",
		"@types/vscode": "^1.85.0",
		"@vitejs/plugin-react": "^4.2.1",
		"@vitest/coverage-istanbul": "^3.2.4",
		"@vscode/test-electron": "^2.5.2",
		"autoprefixer": "^10.4.17",
		"concurrently": "^8.2.2",
		"esbuild": "^0.25.0",
		"eslint": "^9.0.0",
		"eslint-plugin-mocha": "^11.2.0",
		"eslint-plugin-playwright": "^2.9.0",
		"eslint-plugin-react": "^7.37.0",
		"eslint-plugin-react-hooks": "^5.0.0",
		"glob": "^13.0.6",
		"globals": "^15.0.0",
		"husky": "^9.0.0",
		"jsdom": "^25.0.0",
		"lint-staged": "^15.0.0",
		"mocha": "^11.7.5",
		"postcss": "^8.4.33",
		"tailwindcss": "^3.4.1",
		"tsx": "^4.21.0",
		"turbo": "^2.5.8",
		"typescript": "^5.3.3",
		"typescript-eslint": "^8.0.0",
		"vite": "^6.2.0",
		"vitest": "^3.0.0"
	},
	"dependencies": {
		"@floating-ui/react": "^0.27.19",
		"@mdi/js": "^7.4.47",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-context-menu": "^2.2.16",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slider": "^1.3.6",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@types/d3-force": "^3.0.10",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"d3-force": "^3.0.0",
		"distinct-colors": "^3.0.0",
		"ignore": "^7.0.5",
		"minimatch": "^10.1.1",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-force-graph-2d": "^1.29.1",
		"react-force-graph-3d": "^1.29.1",
		"tailwind-merge": "^3.4.0",
		"three": "^0.183.0",
		"three-spritetext": "^1.10.0",
		"zustand": "^5.0.11"
	},
	"overrides": {
		"mocha": {
			"diff": "^8.0.3",
			"serialize-javascript": "^7.0.4"
		}
	}
}
