{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "package-lock.json",
    "tsconfig*.json",
    "packages/**/tsconfig*.json",
    "packages/extension/vite.config.ts"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "typecheck"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["typecheck", "^test"],
      "outputs": []
    },
    "watch": {
      "cache": false,
      "persistent": true
    },
    "watch:extension": {
      "cache": false,
      "persistent": true
    },
    "watch:webview": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
