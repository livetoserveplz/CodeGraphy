{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "pnpm-lock.yaml",
    "tsconfig*.json",
    "packages/**/tsconfig*.json",
    "packages/extension/postcss.config.cjs",
    "packages/extension/tailwind.config.cjs",
    "packages/extension/vite.config.ts"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "test:node": {
      "outputs": []
    },
    "test:webview": {
      "outputs": []
    },
    "test:playwright": {
      "outputs": [
        "$TURBO_ROOT$/dist/webview/**",
        "$TURBO_ROOT$/playwright-report/**",
        "$TURBO_ROOT$/test-results/**"
      ]
    },
    "watch": {
      "cache": false,
      "persistent": true
    },
    "watch:extension": {
      "cache": false,
      "persistent": true
    },
    "watch:webview": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
