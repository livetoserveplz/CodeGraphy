{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@codegraphy/core": ["../core/src/index.ts"],
      "@codegraphy/plugin-markdown": ["../plugin-markdown/src/plugin.ts"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "scripts", "vitest.config.ts", "vitest.includes.ts"],
  "exclude": ["node_modules", "dist", "src/e2e", "../../packages/plugin-*/tests"]
}
