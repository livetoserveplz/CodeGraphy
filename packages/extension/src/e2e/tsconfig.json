{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "lib": ["ES2020"],
    "outDir": "../../../dist-e2e",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false,
    "types": ["mocha", "node"]
  },
  "include": ["./**/*", "../shared/**/*.ts"],
  "exclude": ["node_modules"]
}
