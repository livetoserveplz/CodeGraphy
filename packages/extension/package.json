{
  "name": "@codegraphy/extension",
  "version": "5.2.1",
  "private": true,
  "description": "CodeGraphy VS Code extension core",
  "license": "MIT",
  "engines": {
    "node": ">=22.22.0 <23"
  },
  "scripts": {
    "build": "pnpm run build:extension && pnpm run build:webview",
    "build:extension": "tsx scripts/buildExtension.ts",
    "build:webview": "vite build --config vite.config.ts",
    "watch": "concurrently \"pnpm run watch:extension\" \"pnpm run watch:webview\"",
    "watch:extension": "tsx scripts/buildExtension.ts --watch",
    "watch:webview": "vite build --config vite.config.ts --watch",
    "dev": "pnpm run watch",
    "test": "vitest run --config vitest.config.ts",
    "test:playwright": "playwright test --config playwright.config.ts",
    "test:playwright:ui": "playwright test --config playwright.config.ts --ui",
    "playwright:install": "playwright install chromium",
    "test:watch": "vitest --config vitest.config.ts",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\" \"tests/**/*.{ts,tsx}\"",
    "lint:playwright": "eslint tests/playwright --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.tests.json && tsc --noEmit -p tests/playwright/tsconfig.json"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@ladybugdb/core": "^0.15.3",
    "@mdi/js": "^7.4.47",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "graphology": "^0.26.0",
    "ignore": "^7.0.5",
    "material-icon-theme": "5.33.1",
    "minimatch": "^10.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-force-graph-2d": "^1.29.1",
    "react-force-graph-3d": "^1.29.1",
    "tailwind-merge": "^3.4.0",
    "three": "^0.183.0",
    "three-spritetext": "^1.10.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-c-sharp": "0.23.1",
    "tree-sitter-go": "0.25.0",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "0.25.0",
    "tree-sitter-rust": "0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@types/d3-force": "^3.0.10",
    "@types/mocha": "^10.0.10",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "@vscode/test-electron": "^2.5.2",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "jsdom": "^25.0.0",
    "mocha": "^11.7.5",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "vite": "^6.2.0"
  }
}
