{
  "$schema": "../../codegraphy.schema.json",
  "id": "codegraphy.python",
  "name": "Python",
  "version": "1.0.0",
  "apiVersion": "^2.0.0",
  "tier": 1,
  "supportedExtensions": [".py", ".pyi"],
  "defaultFilters": [
    "**/venv/**",
    "**/.venv/**",
    "**/env/**",
    "**/.env/**",
    "**/__pypackages__/**",
    "**/site-packages/**",
    "**/__pycache__/**",
    "**/.pytest_cache/**",
    "**/.mypy_cache/**",
    "**/.ruff_cache/**",
    "**/.hypothesis/**",
    "**/.pyre/**",
    "**/.pytype/**",
    "**/.tox/**",
    "**/.nox/**",
    "**/.ipynb_checkpoints/**",
    "**/eggs/**",
    "**/*.egg-info/**",
    "**/pip-wheel-metadata/**",
    "**/dist/**",
    "**/build/**",
    "**/.eggs/**"
  ],
  "fileColors": {}
}
