{
  "$schema": "../../codegraphy.schema.json",
  "id": "codegraphy.gdscript",
  "name": "GDScript (Godot)",
  "version": "1.0.0",
  "apiVersion": "^2.0.0",
  "tier": 1,
  "supportedExtensions": [".gd"],
  "defaultFilters": [
    "**/.godot/**",
    "**/.import/**",
    "**/*.import",
    "**/.mono/**",
    "**/addons/**",
    "**/*.uid"
  ],
  "fileColors": {
    "*.gd": { "color": "#478CBF", "shape2D": "diamond", "image": "assets/godot.svg" },
    "*.tscn": { "color": "#6EE7B7", "shape2D": "hexagon" },
    "*.tres": "#5EEAD4",
    "*.gdshader": { "color": "#A78BFA", "shape2D": "triangle" },
    "project.godot": { "color": "#478CBF", "shape2D": "star" }
  },
  "rules": [
    { "id": "preload", "name": "Preload", "description": "preload(\"res://...\")" },
    { "id": "load", "name": "Load", "description": "load(), ResourceLoader.load()" },
    { "id": "extends", "name": "Extends", "description": "extends \"res://...\" or ClassName" },
    { "id": "class-name-usage", "name": "Class Name Usage", "description": "Type annotations, static calls" }
  ]
}
