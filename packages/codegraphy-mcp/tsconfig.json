{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@codegraphy/core": ["../core/src/index.ts"],
      "@codegraphy/plugin-markdown": ["../plugin-markdown/src/plugin.ts"],
      "@codegraphy/plugin-api": ["../plugin-api/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.mjs",
    "vitest.config.ts"
  ]
}
