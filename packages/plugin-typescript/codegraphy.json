{
  "$schema": "../../codegraphy.schema.json",
  "id": "codegraphy.typescript",
  "name": "TypeScript/JavaScript",
  "version": "1.0.0",
  "apiVersion": "^2.0.0",
  "tier": 1,
  "supportedExtensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs"],
  "defaultFilters": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/out/**",
    "**/.next/**",
    "**/.nuxt/**",
    "**/coverage/**",
    "**/.turbo/**"
  ],
  "fileColors": {}
}
