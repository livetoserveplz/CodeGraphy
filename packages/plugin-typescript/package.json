{
  "name": "codegraphy-typescript",
  "displayName": "CodeGraphy TypeScript/JavaScript",
  "version": "1.0.1",
  "description": "Adds TypeScript and JavaScript dependency detection to CodeGraphy. Requires codegraphy.codegraphy.",
  "publisher": "codegraphy",
  "license": "MIT",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#023859",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joesobo/CodeGraphyV4.git"
  },
  "homepage": "https://github.com/joesobo/CodeGraphyV4/tree/main/packages/plugin-typescript",
  "bugs": {
    "url": "https://github.com/joesobo/CodeGraphyV4/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages"
  ],
  "keywords": [
    "codegraphy",
    "codegraphy-plugin",
    "graph",
    "typescript",
    "javascript",
    "dependencies"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:codegraphy.open",
    "onView:codegraphy.graphView"
  ],
  "extensionDependencies": [
    "codegraphy.codegraphy"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist/**",
    "assets/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "build": "esbuild src/activate.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"__tests__/activate.test.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "package:vsix": "mkdir -p ../../artifacts/vsix && pnpm exec vsce package --no-dependencies --out ../../artifacts/vsix/codegraphy.codegraphy-typescript-${npm_package_version}.vsix",
    "publish:vsce": "pnpm exec vsce publish --no-dependencies --skip-duplicate"
  },
  "dependencies": {
    "@codegraphy-vscode/plugin-api": "workspace:*"
  }
}
