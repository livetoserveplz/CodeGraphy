{
  "name": "@codegraphy/plugin-typescript",
  "version": "2.0.4",
  "description": "CodeGraphy TypeScript and JavaScript plugin",
  "license": "MIT",
  "type": "module",
  "main": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joesobo/CodeGraphyV4.git"
  },
  "homepage": "https://github.com/joesobo/CodeGraphyV4/tree/main/packages/plugin-typescript",
  "bugs": {
    "url": "https://github.com/joesobo/CodeGraphyV4/issues"
  },
  "engines": {
    "node": ">=22.22.0 <23"
  },
  "keywords": [
    "codegraphy",
    "codegraphy-plugin",
    "graph",
    "typescript",
    "javascript",
    "dependencies"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "codegraphy.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@codegraphy/plugin-api": "workspace:*"
  },
  "codegraphy": {
    "type": "plugin",
    "apiVersion": "^2.0.0",
    "disclosures": []
  }
}
