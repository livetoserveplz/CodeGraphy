{
  "name": "@codegraphy/plugin-api",
  "version": "0.1.0",
  "description": "Type definitions for CodeGraphy plugins",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts"
    },
    "./webview": {
      "types": "./src/webview/index.ts"
    },
    "./events": {
      "types": "./src/events.ts"
    },
    "./plugin": {
      "types": "./src/plugin.ts"
    }
  },
  "types": "src/index.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT"
}
