{
  "name": "@codegraphy-vscode/plugin-api",
  "version": "1.1.0",
  "description": "Type definitions for CodeGraphy plugins",
  "engines": {
    "node": ">=24.12.0 <25"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joesobo/CodeGraphyV4.git"
  },
  "homepage": "https://github.com/joesobo/CodeGraphyV4/tree/main/packages/plugin-api",
  "bugs": {
    "url": "https://github.com/joesobo/CodeGraphyV4/issues"
  },
  "keywords": [
    "codegraphy",
    "codegraphy-plugin",
    "vscode",
    "plugin-api",
    "types"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts"
    },
    "./webview": {
      "types": "./src/webview/index.ts"
    },
    "./events": {
      "types": "./src/events.ts"
    },
    "./plugin": {
      "types": "./src/plugin.ts"
    }
  },
  "types": "src/index.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT"
}
