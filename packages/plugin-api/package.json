{
  "name": "@codegraphy/plugin-api",
  "version": "2.0.0",
  "description": "Type definitions for CodeGraphy plugins",
  "engines": {
    "node": ">=22.22.0 <23"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joesobo/CodeGraphyV4.git"
  },
  "homepage": "https://github.com/joesobo/CodeGraphyV4/tree/main/packages/plugin-api",
  "bugs": {
    "url": "https://github.com/joesobo/CodeGraphyV4/issues"
  },
  "keywords": [
    "codegraphy",
    "codegraphy-plugin",
    "plugin-api",
    "types"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts"
    },
    "./events": {
      "types": "./src/events.ts"
    },
    "./plugin": {
      "types": "./src/plugin.ts"
    },
    "./access": {
      "types": "./src/access.ts"
    },
    "./data": {
      "types": "./src/data.ts"
    },
    "./graph-view": {
      "types": "./src/graphView.ts"
    },
    "./webview": {
      "types": "./src/webview.ts"
    }
  },
  "types": "src/index.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint src tests vitest.config.ts",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT"
}
